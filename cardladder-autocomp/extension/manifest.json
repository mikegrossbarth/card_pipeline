{
  "manifest_version": 3,
  "name": "Card Ladder Auto-Comp Helper",
  "version": "0.1.0",
  "description": "Runs Card Ladder cert lookups from a prepared queue in your normal Chrome session.",
  "permissions": ["activeTab", "alarms", "debugger", "downloads", "scripting", "storage", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "https://app.cardladder.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Card Ladder Auto-Comp"
  },
  "content_scripts": [
    {
      "matches": ["https://app.cardladder.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
