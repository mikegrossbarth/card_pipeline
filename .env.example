# Required for Photo OCR and Card Ladder screenshot OCR fallback.
GOOGLE_API_KEY=

# Required for complete setup. Enables Google Sheets rule/payout files in Assignment Rules.
# Create an OAuth Client ID with application type "Desktop app" in Google Cloud.
GOOGLE_SHEETS_OAUTH_CLIENT_ID=
GOOGLE_SHEETS_OAUTH_CLIENT_SECRET=

# Required for complete setup. Point this at your WORKING SHEETS folder.
# If this is set, INCOMING SHEETS, RECEIVED SHEETS, and sheet_markers.json live beside it.
# Example: D:\CARD_PIPELINE\WORKING SHEETS
LUCAS_WORKING_SHEETS_DIR=

# Legacy fallback for setups with folders under one pipeline root.
# Example: D:\CARD_PIPELINE
LUCAS_PIPELINE_DIR=
